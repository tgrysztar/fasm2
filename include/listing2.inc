
; Alternative listing generator, which attempts to show any generated bytes,
; including ones in virtual blocks that do not go into the output file.
; It lists the bytes next to their assumed address, limited to the constant term
; when the address is a linear polynomial.
; The listing is stored in a file with .LST extension.

; The listing can be turned off and on for various portions of source text, like:
;	nolist
;		include 'win32a.inc'
;	list

define Listing? Listing

namespace Listing

	ON = 0

	virtual at 0
		HexDigits:: db '0123456789ABCDEF'
	end virtual

	virtual at 0
		Space:: db 24 dup ' '
	end virtual

	Buffer = ''

	define AREA AREA
	define ADDRESS ADDRESS

	match AREA:ADDRESS, AREA:ADDRESS

		macro Setup
			local label
			label:: define AREA label
			ADDRESS = $$
		end macro

	end match

	calminstruction ? &line&
		assemble line
		check	ON
		jno	done

		check	defined AREA & $$ eq AREA metadata 1 & $ - $$ = sizeof AREA
		jyes	area_ok
		asm	Setup
		check	defined AREA & $$ eq AREA metadata 1 & $ - $$ = sizeof AREA
		jno	done
	    area_ok:

		taketext line, line
		jno	done
		stringify line

		local	bytes, counter, text

		compute bytes, $ - ADDRESS
		check	$ - bytes >= $$ & bytes >= 0
		jyes	size_ok
		compute bytes, $ - $$
	    size_ok:

		compute counter, 16
	    print_address:
		compute counter, counter - 1
		load	text, HexDigits:( ADDRESS scale 0 shr (counter shl 2)) and 0Fh, 1
		take	Buffer, text
		check	counter
		jyes	print_address
		compute text, ': '
		take	Buffer, text

		compute ADDRESS, $

		local	bytes_in_row, readable_bytes, data

		check	bytes > 0
		jyes	main
		load	text, Space:0, 8*3
		compute text, text bappend line bappend 13 bappend 10
		take	Buffer, text
		jump	done

	    main:
		compute bytes_in_row, bytes
		check	bytes_in_row <= 8
		jyes	check_bytes
		compute bytes_in_row, 8
	    check_bytes:
		check	$ - bytes + bytes_in_row <= $@
		jyes	all_readable
		check	$ - bytes_in_row >= $@
		jyes	none_readable
		compute readable_bytes, bytes_in_row - ($ - $@)
		jyes	read_bytes
	    all_readable:
		compute readable_bytes, bytes_in_row
		jump	read_bytes
	    none_readable:
		compute readable_bytes, 0
	    read_bytes:
		load	data, AREA:$ - $$ - bytes, readable_bytes
		compute counter, 0
	    print_bytes:
		check	counter < readable_bytes
		jno	print_uninitialized_bytes
		load	text, HexDigits:(data shr (counter shl 3 + 4)) and 0Fh, 1
		take	Buffer, text
		load	text, HexDigits:(data shr (counter shl 3)) and 0Fh, 1
		compute text, text bappend ' '
		take	Buffer, text
		compute counter, counter + 1
		jump	print_bytes
	    print_uninitialized_bytes:
		check	counter < bytes_in_row
		jno	bytes_printed
		compute text, '?? '
		take	Buffer, text
		compute counter, counter + 1
		jump	print_uninitialized_bytes
	    bytes_printed:
		check	line
		jno	line_printed
		load	text, Space:0, (8-bytes_in_row)*3
		take	Buffer, text
		take	Buffer, line
		compute line, ''
	    line_printed:
		compute text, 13 bappend 10
		take	Buffer, text
		check	bytes > bytes_in_row
		jno	done
		compute bytes, bytes - bytes_in_row
		load	text, Space:0, 18
		take	Buffer, text
		jump	main
	    done:

	end calminstruction

end namespace

calminstruction nolist?!
	compute Listing.ON, 0
end calminstruction

calminstruction list?!
	asm	Listing.Setup
	compute Listing.ON, 1
end calminstruction

calminstruction end?.virtual?
	asm	end virtual
	check	Listing.ON
	jyes	reset
	exit
    reset:
	call	nolist?
	call	list?
	compute Listing.ADDRESS, $
end calminstruction

postpone ?
	nolist
	virtual as 'lst'
		calminstruction Listing
			local	stack, line
		    reverse:
			take	stack, Listing.Buffer
			jyes	reverse
		    write:
			take	line, stack
			jno	done
			emit	lengthof line, line
			jump	write
		    done:
		end calminstruction
		Listing
	end virtual
end postpone
list